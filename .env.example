# Shared local development defaults.
RAG_DEBUGGER_ENV=local
RAG_DEBUGGER_LOG=info

# API service.
RAG_DEBUGGER_API_HOST=127.0.0.1
RAG_DEBUGGER_API_PORT=8080
RAG_DEBUGGER_WEB_ORIGIN=http://127.0.0.1:5173
RAG_DEBUGGER_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rag_debugger

# Product identity.
RAG_DEBUGGER_PRODUCT_NAME=CorpusLab
RAG_DEBUGGER_WORKSPACE_NAME=Corpus Workspace
RAG_DEBUGGER_DEPLOYMENT_MODE=hybrid
RAG_DEBUGGER_STORAGE_BACKEND=postgres

# Local auth and workspace bootstrap.
RAG_DEBUGGER_AUTH_PROVIDER=local
RAG_DEBUGGER_SESSION_COOKIE_NAME=corpuslab_session
RAG_DEBUGGER_SESSION_TTL_HOURS=168
RAG_DEBUGGER_SESSION_COOKIE_SECURE=false
RAG_DEBUGGER_BOOTSTRAP_EMAIL=demo@corpuslab.ai
RAG_DEBUGGER_BOOTSTRAP_PASSWORD=CorpusLab#2026
RAG_DEBUGGER_BOOTSTRAP_USER_NAME=Demo User
RAG_DEBUGGER_BOOTSTRAP_ORGANIZATION=CorpusLab Demo Organization
RAG_DEBUGGER_BOOTSTRAP_WORKSPACE=Corpus Demo Workspace

# Ingestion limits and supported file types.
RAG_DEBUGGER_MAX_FILES_PER_REQUEST=10
RAG_DEBUGGER_MAX_FILE_BYTES=20971520
RAG_DEBUGGER_MAX_REQUEST_BYTES=52428800
RAG_DEBUGGER_PREVIEW_CHUNK_LIMIT=8
RAG_DEBUGGER_SUPPORTED_EXTENSIONS=txt,md,markdown,html,htm,pdf

# Chunking defaults.
RAG_DEBUGGER_DEFAULT_TARGET_TOKENS=512
RAG_DEBUGGER_DEFAULT_OVERLAP_TOKENS=64
RAG_DEBUGGER_DEFAULT_CHUNKING_STRATEGY=structured

# Retrieval defaults and scoring weights.
RAG_DEBUGGER_DEFAULT_TOP_K=5
RAG_DEBUGGER_MAX_TOP_K=25
RAG_DEBUGGER_DEFAULT_RETRIEVAL_MODE=hybrid
RAG_DEBUGGER_MIN_EVIDENCE_SCORE=0.35
RAG_DEBUGGER_MIN_SEMANTIC_SIMILARITY=0.25
RAG_DEBUGGER_ANSWER_CITATION_LIMIT=3
RAG_DEBUGGER_WEIGHT_SEMANTIC_HYBRID=2.0
RAG_DEBUGGER_WEIGHT_SEMANTIC_VECTOR=3.0
RAG_DEBUGGER_WEIGHT_LEXICAL=2.4
RAG_DEBUGGER_WEIGHT_FREQUENCY=0.6
RAG_DEBUGGER_WEIGHT_PHRASE=1.2
RAG_DEBUGGER_WEIGHT_SECTION=0.75
RAG_DEBUGGER_WEIGHT_PATH=0.5
RAG_DEBUGGER_WEIGHT_METADATA=1.0

# Local embedding provider.
RAG_DEBUGGER_EMBEDDING_PROVIDER=local
RAG_DEBUGGER_EMBEDDING_MODEL=local-hash-v1
RAG_DEBUGGER_EMBEDDING_DIMENSION=384

# Web app.
VITE_API_BASE_URL=http://127.0.0.1:8080
RAG_DEBUGGER_SHOW_LOCAL_BADGES=true
